# Copy this file to .env.testing (gitignored) and fill in your local
# Postgres credentials + your APP_KEY. Laravel loads .env.testing
# automatically when APP_ENV=testing (set in phpunit.xml).
#
# Why this file exists: phpunit.xml deliberately sets no DB env vars
# because phpunit's <env> entries take precedence over .env files
# (Dotenv runs in immutable mode). If we set DB_PASSWORD="" in
# phpunit.xml, your local password in .env.testing would be silently
# overridden. So the only place the password lives is in this gitignored
# file.

APP_ENV=testing
# Copy from your local .env (must match — encryption keys are project-scoped).
APP_KEY=base64:REPLACE_WITH_YOUR_LOCAL_APP_KEY
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=task_manager_test
DB_USERNAME=postgres
DB_PASSWORD=REPLACE_WITH_YOUR_LOCAL_PG_PASSWORD
